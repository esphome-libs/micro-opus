# Common defaults for all targets.
# Target-specific overrides live in sdkconfig.defaults.<target>.

# Disable watchdog (benchmark runs continuously)
CONFIG_ESP_TASK_WDT_EN=n
CONFIG_ESP_TASK_WDT_INIT=n

# Adequate stack for Opus
CONFIG_ESP_MAIN_TASK_STACK_SIZE=10000

# Maximum CPU frequency
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Performance optimization
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# Enable PSRAM (mode/speed set per-target)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_CAPS_ALLOC=y

# Opus configuration - use threadsafe pseudostack for multi-task safety
CONFIG_OPUS_THREADSAFE_PSEUDOSTACK=y

# Disable internal timing instrumentation (we do our own timing)
CONFIG_OPUS_ENABLE_CELT_TIMING=n
CONFIG_OPUS_ENABLE_PVQ_TIMING=n
CONFIG_OPUS_ENABLE_QUANT_BANDS_TIMING=n

# Use floating point (both ESP32 and ESP32-S3 have FPU)
CONFIG_OPUS_FLOATING_POINT=y
